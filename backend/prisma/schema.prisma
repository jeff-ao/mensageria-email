// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Clientes {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())

  Interesses Interesses[]
}

model Corretores {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())

  Imoveis Imoveis[]
}

model Imoveis {
  id        Int      @id @default(autoincrement())
  tipo   String
  corretorId Int
  metragem     Float
  bairro      String
  createdAt DateTime @default(now())

  Corretores   Corretores @relation(fields: [corretorId], references: [id])
}

model Interesses {
  id        Int      @id @default(autoincrement())
  clienteId Int
  metragem     Float
  bairro      String

  createdAt DateTime @default(now())
  Clientes   Clientes @relation(fields: [clienteId], references: [id])
}